# Copy values into /opt/fv-app/.env.production by running bash init.sh.
# Never commit the real /opt/fv-app/.env.production file.

APP_DOMAIN=example.com

POSTGRES_USER=future_viewer
POSTGRES_PASSWORD=change-me-generate-with-init
POSTGRES_DB=future_viewer

JWT_SECRET=change-me-generate-with-init-at-least-32-chars
JWT_ISSUER=future-viewer
JWT_AUDIENCE=future-viewer

AI_PROVIDER=OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Leave empty for same-origin production API via Caddy.
VITE_API_URL=
VITE_SITE_URL=https://example.com

# Optional search verification and analytics ids. Analytics scripts are not loaded by default.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_YANDEX_VERIFICATION=
VITE_YANDEX_METRICA_ID=
VITE_GOOGLE_ANALYTICS_ID=

# Public payment/legal details compiled into the frontend.
VITE_MERCHANT_SERVICE_NAME="Future Viewer"
VITE_MERCHANT_OWNER_NAME="Дунецев Александр Дмитриевич"
VITE_MERCHANT_TAX_STATUS="самозанятый, плательщик налога на профессиональный доход"
VITE_MERCHANT_INN=592108465422
VITE_MERCHANT_PHONE=79967669613
VITE_MERCHANT_EMAIL=duntsev010@mail.ru
VITE_MERCHANT_POSTAL_ADDRESS=duntsev010@mail.ru
VITE_PAID_PRODUCT_TITLE="Доступ Future Viewer Pro"
VITE_PAID_PRODUCT_PRICE="300 ₽"
VITE_PAID_PRODUCT_PERIOD="30 дней"
VITE_PAID_PRODUCT_DESCRIPTION="Цифровая услуга доступа к безлимитным Таро-раскладам в онлайн-сервисе Future Viewer без автопродления."

# For multiple admins, init.sh writes Admin__Emails__0, Admin__Emails__1, ...
Admin__Emails__0=admin@example.com
SUPPORT_EMAIL=support@example.com

# Telegram is optional. Empty token disables bot features.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=FutureViewerBot

# SMTP is optional. Empty host logs verification links instead of sending email.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@example.com
EMAIL_USE_SSL=true

# Payment provider: Yukassa or YooMoney.
PAYMENT_PROVIDER=Yukassa

# YooKassa is optional until paid subscriptions are enabled with YooKassa.
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_CURRENCY=RUB
YUKASSA_MONTHLY_PRICE_AMOUNT=300
YUKASSA_API_BASE_URL=https://api.yookassa.ru/v3/

# YooMoney redirect flow. Receiver is the YooMoney wallet number, not a payout gate id.
YOOMONEY_RECEIVER=
YOOMONEY_NOTIFICATION_SECRET=
YOOMONEY_QUICKPAY_URL=https://yoomoney.ru/quickpay/confirm
YOOMONEY_QUICKPAY_FORM=button
YOOMONEY_PAYMENT_TYPE=AC
YOOMONEY_CURRENCY_CODE=643
YOOMONEY_MONTHLY_PRICE_AMOUNT=300
YOOMONEY_TARGETS="Доступ Future Viewer Pro"
