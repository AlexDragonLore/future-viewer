# Copy values into /opt/fv-app/.env.production by running bash init.sh.
# Never commit the real /opt/fv-app/.env.production file.

APP_DOMAIN=example.com

POSTGRES_USER=future_viewer
POSTGRES_PASSWORD=change-me-generate-with-init
POSTGRES_DB=future_viewer

JWT_SECRET=change-me-generate-with-init-at-least-32-chars
JWT_ISSUER=future-viewer
JWT_AUDIENCE=future-viewer

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Leave empty for same-origin production API via Caddy.
VITE_API_URL=

# For multiple admins, init.sh writes Admin__Emails__0, Admin__Emails__1, ...
Admin__Emails__0=admin@example.com
SUPPORT_EMAIL=support@example.com

# Telegram is optional. Empty token disables bot features.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=FutureViewerBot

# SMTP is optional. Empty host logs verification links instead of sending email.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@example.com
EMAIL_USE_SSL=true

# YooKassa is optional until paid subscriptions are enabled.
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_CURRENCY=RUB
YUKASSA_MONTHLY_PRICE_AMOUNT=300
YUKASSA_API_BASE_URL=https://api.yookassa.ru/v3/
