FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install

FROM node:22-alpine AS dev
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

FROM node:22-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG VITE_API_URL=http://localhost:5000
ARG VITE_MERCHANT_SERVICE_NAME="Future Viewer"
ARG VITE_MERCHANT_OWNER_NAME="Дунецев Александр Дмитриевич"
ARG VITE_MERCHANT_TAX_STATUS="самозанятый, плательщик налога на профессиональный доход"
ARG VITE_MERCHANT_INN=592108465422
ARG VITE_MERCHANT_PHONE=79967669613
ARG VITE_MERCHANT_EMAIL=duntsev010@mail.ru
ARG VITE_MERCHANT_POSTAL_ADDRESS=duntsev010@mail.ru
ARG VITE_PAID_PRODUCT_TITLE="Подписка Future Viewer Pro"
ARG VITE_PAID_PRODUCT_PRICE="300 ₽"
ARG VITE_PAID_PRODUCT_PERIOD="1 месяц"
ARG VITE_PAID_PRODUCT_DESCRIPTION="Цифровая услуга доступа к безлимитным Таро-раскладам в онлайн-сервисе Future Viewer."
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_MERCHANT_SERVICE_NAME=$VITE_MERCHANT_SERVICE_NAME
ENV VITE_MERCHANT_OWNER_NAME=$VITE_MERCHANT_OWNER_NAME
ENV VITE_MERCHANT_TAX_STATUS=$VITE_MERCHANT_TAX_STATUS
ENV VITE_MERCHANT_INN=$VITE_MERCHANT_INN
ENV VITE_MERCHANT_PHONE=$VITE_MERCHANT_PHONE
ENV VITE_MERCHANT_EMAIL=$VITE_MERCHANT_EMAIL
ENV VITE_MERCHANT_POSTAL_ADDRESS=$VITE_MERCHANT_POSTAL_ADDRESS
ENV VITE_PAID_PRODUCT_TITLE=$VITE_PAID_PRODUCT_TITLE
ENV VITE_PAID_PRODUCT_PRICE=$VITE_PAID_PRODUCT_PRICE
ENV VITE_PAID_PRODUCT_PERIOD=$VITE_PAID_PRODUCT_PERIOD
ENV VITE_PAID_PRODUCT_DESCRIPTION=$VITE_PAID_PRODUCT_DESCRIPTION
RUN npm run build

FROM nginx:1.27-alpine AS prod
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
